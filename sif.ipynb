import os
import subprocess
import random
import string
import time

def run(cmd):
    print(f"[RUN] {cmd}")
    subprocess.run(cmd, shell=True)

def secret():
    return ''.join(random.choice("abcdef0123456789") for _ in range(32))

def get_ip():
    try:
        ip = subprocess.check_output("curl -s ifconfig.me", shell=True)
        return ip.decode().strip()
    except:
        return "0.0.0.0"

print("Installing dependencies...")

run("apt update")
run("apt install git build-essential curl -y")

print("Downloading MTProxy...")

run("git clone https://github.com/TelegramMessenger/MTProxy")

os.chdir("MTProxy")

print("Building MTProxy...")

run("make")

sec = secret()
port = "8080"

ip = get_ip()

print("\n==============================")
print("MTProto Proxy Ready")
print("==============================")

print("Server:", ip)
print("Port:", port)
print("Secret:", sec)

print("\nTelegram Link:")

print(f"https://t.me/proxy?server={ip}&port={port}&secret={sec}")

print("==============================")

cmd = f"./objs/bin/mtproto-proxy -u nobody -p 8888 -H {port} -S {sec} --aes-pwd proxy-secret proxy-multi.conf -M 1"

subprocess.Popen(cmd, shell=True)

while True:
    time.sleep(60)
